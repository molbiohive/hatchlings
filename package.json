{
	"name": "@molbiohive/hatchlings",
	"version": "0.7.0",
	"description": "Svelte 5 molecular biology component library — pure rendering components for scientific visualizations",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && bun run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"3dmol": "^2.4.2"
	},
	"peerDependenciesMeta": {
		"3dmol": {
			"optional": true
		}
	},
	"devDependencies": {
		"3dmol": "^2.4.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"publint": "^0.3.17",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitepress": "^1.6.4"
	},
	"keywords": [
		"svelte",
		"molecular-biology",
		"bioinformatics",
		"plasmid",
		"gel-electrophoresis",
		"chromatogram",
		"scientific-visualization",
		"svelte5"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/molbiohive/hatchlings.git"
	}
}
